# ──────────────────────────────────────────────
# Open WebUI Theme — environment variables
# Copy this file to .env and adjust as needed
# ──────────────────────────────────────────────

# Public backend base URL (used before /api/ai/... paths).
# Production keeps this empty — requests are same-origin via Caddy.
# Local dev: set to your backend URL (e.g. http://localhost:8888)
NEXT_PUBLIC_API_URL=

# Comma-separated AI model list for the selector.
# The first entry is the default model.
NEXT_PUBLIC_AI_MODELS=panyakorn-local:latest